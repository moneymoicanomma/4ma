# Core: Vercel + AWS RDS + Cloudflare R2
DATABASE_URL=postgresql://usuario:senha@host:5432/mmmma
DATABASE_POOL_MAX_CONNECTIONS=5
DATABASE_SSL_MODE=require
DATABASE_SSL_ALLOW_INVALID_CERTIFICATES=false
NEXT_PUBLIC_SITE_ASSET_BASE_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
ALLOWED_FORM_ORIGINS=http://localhost:3000,https://seu-dominio.com

# Public forms protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# SEO / domain verification
GOOGLE_SITE_VERIFICATION=
FACEBOOK_DOMAIN_VERIFICATION=

# Optional: private fighter portal
# shared_password = email livre + senha enviada pela equipe
# account = conta persistida em app.accounts
EVENT_FIGHTER_PORTAL_ENABLED=false
EVENT_FIGHTER_ACCESS_AUTH_MODE=shared_password
ATHLETE_FORM_PASSWORD=gere-uma-senha-forte-e-exclusiva
ATHLETE_FORM_SESSION_SECRET=gere-um-segredo-proprio-para-o-portal
# Admin login fallback (quando DATABASE_URL não está configurado no app)
ADMIN_SESSION_SECRET=gere-um-segredo-forte-para-o-cookie-admin
# Opção 1 (simples): credencial única (role admin)
ADMIN_USERNAME=admin@seudominio.com
ADMIN_PASSWORD=gere-uma-senha-forte
# Opção 2 (multi-usuário): uma linha JSON com roles (admin/operator/auditor)
# ADMIN_CREDENTIALS_JSON=[{"username":"admin@seudominio.com","password":"senha-admin","role":"admin"},{"username":"auditoria@seudominio.com","password":"senha-auditoria","role":"auditor"}]
# Opção 3 (pares dedicados por role)
# ADMIN_OPERATOR_USERNAME=operacao@seudominio.com
# ADMIN_OPERATOR_PASSWORD=senha-operacao
# ADMIN_AUDITOR_USERNAME=auditoria@seudominio.com
# ADMIN_AUDITOR_PASSWORD=senha-auditoria
APP_ENCRYPTION_KEY=gere-um-segredo-longo-e-aleatorio
UPSTREAM_API_BASE_URL=https://sua-function-url.lambda-url.us-east-2.on.aws
UPSTREAM_PUBLIC_WRITE_BEARER_TOKEN=token-so-para-formularios-publicos
UPSTREAM_PORTAL_BEARER_TOKEN=token-so-para-portal-do-atleta
UPSTREAM_ADMIN_READ_BEARER_TOKEN=token-so-para-leitura-admin
UPSTREAM_ADMIN_WRITE_BEARER_TOKEN=token-so-para-escrita-admin
# legado temporario para compatibilidade:
# UPSTREAM_API_BEARER_TOKEN=gere-um-token-servidor-aqui
UPSTREAM_EVENT_FIGHTER_ACCESS_PATH=/v1/event-fighter-access/session
UPSTREAM_ADMIN_DATABASE_OVERVIEW_PATH=/v1/admin/database-overview
UPSTREAM_FANTASY_EVENTS_PATH=/v1/fantasy/events
UPSTREAM_ADMIN_FANTASY_EVENTS_PATH=/v1/admin/fantasy/events
UPSTREAM_EVENT_FIGHTER_INTAKE_PATH=/v1/event-fighter-intakes
UPSTREAM_FANTASY_ENTRY_PATH=/v1/fantasy/entries
FIGHTER_PHOTOS_STORAGE_PROVIDER=r2
FIGHTER_PHOTOS_S3_BUCKET=mmmma-fighter-photos
FIGHTER_PHOTOS_S3_REGION=auto
FIGHTER_PHOTOS_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
FIGHTER_PHOTOS_S3_ACCESS_KEY_ID=
FIGHTER_PHOTOS_S3_SECRET_ACCESS_KEY=
FIGHTER_PHOTOS_S3_FORCE_PATH_STYLE=false
