# Core: Vercel + AWS RDS + Cloudflare R2
DATABASE_URL=postgresql://usuario:senha@host:5432/mmmma
DATABASE_POOL_MAX_CONNECTIONS=5
DATABASE_SSL_MODE=require
NEXT_PUBLIC_SITE_ASSET_BASE_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
ALLOWED_FORM_ORIGINS=http://localhost:3000,https://seu-dominio.com

# Public forms protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# SEO / domain verification
GOOGLE_SITE_VERIFICATION=
FACEBOOK_DOMAIN_VERIFICATION=

# Optional: private fighter portal
# shared_password = email livre + senha enviada pela equipe
# account = conta persistida em app.accounts
EVENT_FIGHTER_PORTAL_ENABLED=false
EVENT_FIGHTER_ACCESS_AUTH_MODE=shared_password
ATHLETE_FORM_PASSWORD=
ATHLETE_FORM_SESSION_SECRET=gere-um-segredo-proprio-para-o-portal
APP_ENCRYPTION_KEY=gere-um-segredo-longo-e-aleatorio
UPSTREAM_API_BASE_URL=https://sua-function-url.lambda-url.us-east-2.on.aws
UPSTREAM_API_BEARER_TOKEN=gere-um-token-servidor-aqui
UPSTREAM_EVENT_FIGHTER_ACCESS_PATH=/v1/event-fighter-access/session
UPSTREAM_EVENT_FIGHTER_INTAKE_PATH=/v1/event-fighter-intakes
FIGHTER_PHOTOS_STORAGE_PROVIDER=r2
FIGHTER_PHOTOS_S3_BUCKET=mmmma-fighter-photos
FIGHTER_PHOTOS_S3_REGION=auto
FIGHTER_PHOTOS_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
FIGHTER_PHOTOS_S3_ACCESS_KEY_ID=
FIGHTER_PHOTOS_S3_SECRET_ACCESS_KEY=
FIGHTER_PHOTOS_S3_FORCE_PATH_STYLE=false
